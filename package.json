{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "description": "Forge generator implementation",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "bin": {
    "forge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --platform node --target node20 --out-dir dist --clean",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
